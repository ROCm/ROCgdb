} else {
    foreach line [split $filt_output "\n"] {
	if {![regexp {^\s+0x[0-9a-fA-F]+:} $line]} { continue }
	if {[regexp {LF_MFUNCTION} $line]} {
	    set has_target 1
	    if {[regexp {ret=} $line]} { set has_ret 1 }
	    if {[regexp {class=} $line]} { set has_class 1 }
	    if {[regexp {this=} $line]} { set has_this 1 }
	    if {[regexp {args=} $line]} { set has_args 1 }
	} else {
	    set has_other 1
	}
    }
    set ok 1
    if {!$has_target} { set ok 0; send_user "FAIL: no LF_MFUNCTION records\n" }
    if {$has_other} { set ok 0; send_user "FAIL: non-MFUNCTION records leaked\n" }
    if {!$has_ret} { set ok 0; send_user "FAIL: no ret= xref\n" }
    if {!$has_class} { set ok 0; send_user "FAIL: no class= xref\n" }
    if {!$has_this} { set ok 0; send_user "FAIL: no this= xref\n" }
    if {!$has_args} { set ok 0; send_user "FAIL: no args= xref\n" }
    if {$ok} {
	pass "maintenance info pdb-types kind=LF_MFUNCTION"
    } else {
	fail "maintenance info pdb-types kind=LF_MFUNCTION"
    }
}

# ===================================================================
# kind=LF_ARGLIST
# ===================================================================

set has_target 0
set has_other 0
set has_count 0
set has_arg 0

set filt_result [catch {exec sh -c "$GDB -nw -nx -q \
    -iex \"set height 0\" \
    -iex \"set width 0\" \
    -ex \"set debug-file-directory \\\"\\\"\" \
    -ex \"maintenance info pdb-types kind=LF_ARGLIST\" \
    -ex \"quit\" \
    $exe 2>&1 | grep -e \"0x\[0-9a-f\]\""} filt_output]

if {$filt_result != 0 || $filt_output eq ""} {
    fail "maintenance info pdb-types kind=LF_ARGLIST: no output"
} else {
    foreach line [split $filt_output "\n"] {
	if {![regexp {^\s+0x[0-9a-fA-F]+:} $line]} { continue }
	if {[regexp {LF_ARGLIST} $line]} {
	    set has_target 1
	    if {[regexp {count=} $line]} { set has_count 1 }
	    if {[regexp {arg=} $line]} { set has_arg 1 }
	} else {
	    set has_other 1
	}
    }
    set ok 1
    if {!$has_target} { set ok 0; send_user "FAIL: no LF_ARGLIST records\n" }
    if {$has_other} { set ok 0; send_user "FAIL: non-ARGLIST records leaked\n" }
    if {!$has_count} { set ok 0; send_user "FAIL: no count= xref\n" }
    if {!$has_arg} { set ok 0; send_user "FAIL: no arg= xref\n" }
    if {$ok} {
	pass "maintenance info pdb-types kind=LF_ARGLIST"
    } else {
