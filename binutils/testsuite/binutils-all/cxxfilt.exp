proc test_cxxfilt {options mangled_string demangled_string} {
    global CXXFILT
    global CXXFILTFLAGS
    
    set testname "cxxfilt: demangling $mangled_string"
    set got [binutils_run $CXXFILT "$options $CXXFILTFLAGS $mangled_string"]

    if ![regexp $demangled_string $got] then {
	fail "$testname"
	verbose 0 "expected: $demangled_string"
	return
    }

    pass $testname
}

# Improved test so that templates can be specified properly.
proc test_cxxfilt_msvc {options mangled_string demangled_string} {
    global CXXFILT
    global CXXFILTFLAGS

    set testname "cxxfilt: demangling $mangled_string"
    set got [binutils_run $CXXFILT "$options $CXXFILTFLAGS $mangled_string"]

    if {[string first $demangled_string $got] == -1} then {
	fail "$testname"
	send_user "EXPECTED: $demangled_string\n"
	send_user "GOT:      $got\n"
	return
    }

    pass $testname
}


# Mangled and demangled strings stolen from libiberty/testsuite/demangle-expected.
test_cxxfilt {--no-strip-underscores} \
    "_Z1fIvJiELb0EEvPDOT1_EFT_DpT0_E" \
    "void f.void, int, false.(void (.)(int) noexcept(false))*"

test_cxxfilt {--format=gnu-v3 --no-strip-underscores} \
    "_Z14int_if_addableI1YERiP1AIXszpldecvPT_Li0EdecvS4_Li0EEE" \
    "int& int_if_addable.Y.(A.sizeof ((.((Y.)(0))).(.((Y.)(0))))..)*"

test_cxxfilt {--no-recurse-limit} \
    "Z3fooiPiPS_PS0_PS1_PS2_PS3_PS4_PS5_PS6_PS7_PS8_PS9_PSA_PSB_PSC_" \
    "foo(int, int., int.., int..., int...., int....., int......, int......., int........, int........., int.........., int..........., int............, int............., int.............., int...............)*"

# Do the same functions but with MSVC mangling.

# When binutils are built with libdemangle-msvc the help command
# will mention MSVC.  Use it as a test for msvc demangler presence.
global have_msvc_demangler
set have_msvc_demangler 0
set probe_got [binutils_run $CXXFILT "--help"]
if {[string first "--msvc-full" $probe_got] != -1} {
    set have_msvc_demangler 1
} else {
    untested "cxxfilt: MSVC demangler not built in -- skipping MSVC tests"
}

if {$have_msvc_demangler} {

# Exercise the -s/--format=msvc style selector.
test_cxxfilt_msvc {--no-strip-underscores -s msvc} \
    {?foo@@YAXXZ} \
    {void __cdecl foo(void)}

test_cxxfilt_msvc {--no-strip-underscores --format=msvc} \
    {?bar@@YAHDH@Z} \
    {int __cdecl bar(char, int)}

# With -s msvc, non-MSVC mangled names are not demangled (no Itanium
# fall-through).  The input should come back unchanged.
test_cxxfilt_msvc {--no-strip-underscores -s msvc} \
    {_Z3foov} \
    {_Z3foov}

test_cxxfilt_msvc {--no-strip-underscores} \
    {??$f@XH$0A@@@YAXP6AXH@Z@Z} \
    {void f<void, int, 0>(void ( *)(int))}

test_cxxfilt {--no-strip-underscores} \
    {??$int_if_addable@UY@@@@YAAEAHPEAU?$A@$00@@@Z} \
    {int & int_if_addable< Y>( A<1> *)*}

test_cxxfilt {--no-recurse-limit} \
    {?foo@@@Z} \
    {foo(int, int., int.., int..., int...., int....., int......, int......., int........, int........., int.........., int..........., int............, int............., int.............., int...............)*}

test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {??$f@XH$0A@@@YAXP6AXH@Z@Z} \
    {void f<void, int, 0>}

test_cxxfilt_msvc {--no-strip-underscores --no-verbose} \
    {??$f@XH$0A@@@YAXP6AXH@Z@Z} \
    {void f<void, int, 0>}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?m3@C@@IAEXI@Z} \
    {protected: void __thiscall C::m3(unsigned int)}

# Basic free functions and templates.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?foo@@YAXXZ} \
    {void foo(void)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {?bar@@YAHDH@Z} \
    {int bar(char, int)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {??$func@H@@YAHH@Z} \
    {int func<int>(int)}

# Calling-convention variants.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?stdcallFunc@@YGXXZ} \
    {void stdcallFunc(void)}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?stdcallFunc@@YGXXZ} \
    {void __stdcall stdcallFunc(void)}

# Function-pointer parameters.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?callback@Cb@@QEAAXP6AXH@Z@Z} \
    {void Cb::callback(void ( *)(int))}

# Variadics with const-qualified member function.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?log@PM2@@QEBAUPM3@@PEAEPEBHPEBUPM4@@AEBUData@PM2@@ZZ} \
    {PM3 PM2::log(unsigned char *, int const *, PM4 const *, PM2::Data const &, ...) const}

# MSVC compiler-emitted prefixes ($unwind$, $pdata$, $xdata$, $LN<n>$)
# are peeled by cxxfilt before demangling and re-attached to the
# result.  This mirrors what bfd_demangle does for BFD-using tools
# (objdump, nm, addr2line).
test_cxxfilt_msvc {--no-strip-underscores} \
    {$unwind$?foo@@YAXXZ} \
    {void foo(void)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {$pdata$?bar@@YAHDH@Z} \
    {int bar(char, int)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {$xdata$?baz@@YAXH@Z} \
    {void baz(int)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {$LN4$?foo@@YAXXZ} \
    {void foo(void)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {$LN42$?bar@@YAHDH@Z} \
    {int bar(char, int)}

# More calling-convention coverage.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?fastcallFunc@@YGFH@Z} \
    {short fastcallFunc(int)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {?ptrFunc@@YGHPAH@Z} \
    {int ptrFunc(int *)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {?restrictFunc@@YGXQAI@Z} \
    {void restrictFunc(unsigned int *const)}

# Member-pointer / nested template argument type.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?templ1@?$vector@H@@QAEXH@Z} \
    {void vector<int>::templ1(int)}

test_cxxfilt_msvc {--no-strip-underscores} \
    {??$templ2@V?$vector@H@@@@YA?AV?$vector@H@@I@Z} \
    {vector<int> templ2< vector<int>>(unsigned int)}

# Multiple references and pointer-to-pointer parameters.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?sum@@YAHAAVPM4@@PEAPEAVPM5@@PEAVPM2@PM1@@VPM3@@@Z} \
    {int sum( PM4 &, PM5 **, PM1::PM2 *, PM3)}

# Volatile this and const this on member functions.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?log@PM2@@QEAAXPECVPM2@@@Z} \
    {void PM2::log( PM2 volatile *)}

# Function-pointer parameter returning a struct.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?apply@Func@@YAXP6AHH@Z@Z} \
    {void Func::apply(int ( *)(int))}

test_cxxfilt_msvc {--no-strip-underscores} \
    {?apply@Func@@QAAXP6AUPM1@PM2@@H@Z@Z} \
    {void Func::apply( PM2::PM1 ( *)(int))}

# Two function-pointer parameters.
test_cxxfilt_msvc {--no-strip-underscores} \
    {?call_both@@YAXP6A_NH@ZP6AMHD@Z@Z} \
    {void call_both(bool ( *)(int), float ( *)(int, char))}

# Heavy nested template returning const reference.
test_cxxfilt_msvc {--no-strip-underscores} \
    {??$_Immortalize_memcpy_image@V_Iostream_error_category2@std@@@std@@YAAEBV_Iostream_error_category2@0@XZ} \
    {std::_Iostream_error_category2 const & std::_Immortalize_memcpy_image< std::_Iostream_error_category2>(void)}

# --no-params: drop the parameter list.
test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {?foo@@YAXXZ} \
    {void foo}

test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {?bar@@YAHDH@Z} \
    {int bar}

test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {?flush@?$basic_ostream@DU?$char_traits@D@std@@@std@@QEAAAEAV12@XZ} \
    {std::basic_ostream<char, std::char_traits<char>> & std::basic_ostream<char, std::char_traits<char>>::flush}

test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {?rdbuf@?$basic_ios@DU?$char_traits@D@std@@@std@@QEBAPEAV?$basic_streambuf@DU?$char_traits@D@std@@@2@XZ} \
    {std::basic_streambuf<char, std::char_traits<char>> * std::basic_ios<char, std::char_traits<char>>::rdbuf const}

test_cxxfilt_msvc {--no-strip-underscores --no-params} \
    {?sputc@?$basic_streambuf@DU?$char_traits@D@std@@@std@@QEAAHD@Z} \
    {int std::basic_streambuf<char, std::char_traits<char>>::sputc}

# --msvc-full: emit calling-convention and access qualifiers.
test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?bar@@YAHDH@Z} \
    {int __cdecl bar(char, int)}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?baz@@YAXH@Z} \
    {void __cdecl baz(int)}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?fastcallFunc@@YGFH@Z} \
    {short __stdcall fastcallFunc(int)}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full} \
    {?ptrFunc@@YGHPAH@Z} \
    {int __stdcall ptrFunc(int *)}

# --msvc-full --no-params combined.
test_cxxfilt_msvc {--no-strip-underscores --msvc-full --no-params} \
    {?m4@C@@MAEHXZ} \
    {int __thiscall C::m4}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full --no-params} \
    {?stdcallFunc@@YGXXZ} \
    {void __stdcall stdcallFunc}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full --no-params} \
    {?fastcallFunc@@YGFH@Z} \
    {short __stdcall fastcallFunc}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full --no-params} \
    {?ptrFunc@@YGHPAH@Z} \
    {int __stdcall ptrFunc}

test_cxxfilt_msvc {--no-strip-underscores --msvc-full --no-params} \
    {?restrictFunc@@YGXQAI@Z} \
    {void __stdcall restrictFunc}

} ;# end if {$have_msvc_demangler}
